# Flask Environment Configuration
# Copy this file to .env and fill in your actual values

# Environment mode: development or production
FLASK_ENV=development

# Secret key for session encryption and CSRF protection
# IMPORTANT: Generate a secure random key for production using:
# python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=your_secure_secret_key_here_change_this

# Maximum upload file size in bytes (10 MB default)
MAX_CONTENT_LENGTH=10485760

# Upload directory path (relative to project root)
UPLOAD_FOLDER=uploads

# Cleanup interval in seconds (3600 = 1 hour)
CLEANUP_INTERVAL=3600

# Server port (only used if running directly with python app.py)
PORT=5000

